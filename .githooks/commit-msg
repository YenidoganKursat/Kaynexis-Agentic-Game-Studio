#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:-}"
if [[ -z "${MSG_FILE}" || ! -f "${MSG_FILE}" ]]; then
  exit 0
fi

FIRST_LINE="$(head -n 1 "$MSG_FILE")"
if [[ ! "$FIRST_LINE" =~ ^(feat|fix|docs|chore|refactor|test|build|perf|design|release|ops)(\(.+\))?:\  ]]; then
  echo "Commit message should start with one of:"
  echo "  feat:, fix:, docs:, chore:, refactor:, test:, build:, perf:, design:, release:, ops:"
  echo "Example: feat(combat): add parry timing window"
  exit 1
fi

if [[ "$FIRST_LINE" =~ ^(release|version)(\(.+\))?:\  ]] || [[ "$FIRST_LINE" =~ ^[a-z]+\([^)]*(version|release)[^)]*\):\  ]]; then
  BODY="$(tail -n +2 "$MSG_FILE" | tr -d '\r' | sed '/^[[:space:]]*$/d')"
  if ! grep -Eq '^(What changed:|Changes:|- )' <<<"$BODY"; then
    echo "Versioning and release commits should include a short body that says what changed."
    echo "Example:"
    echo "  feat(versioning): record release-note summary for 2.1.0-dev"
    echo ""
    echo "  What changed:"
    echo "  - updated VERSION to 2.1.0-dev"
    echo "  - synced CHANGELOG.md with the new state"
    echo "  - kept the tag policy aligned"
    exit 1
  fi
fi
